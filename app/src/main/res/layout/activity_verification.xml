<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PP-OCRv5 検証ツール"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Image display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnPrevImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tvImageName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(no image)"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="fitCenter"
                    android:background="#EEEEEE" />

            </LinearLayout>

            <Button
                android:id="@+id/btnNextImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvImageInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:typeface="monospace"
            android:padding="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="8dp" />

        <!-- Stage 0: Image Load -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F0F0F0"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stage 0: Image Load"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStage0Result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(not run)"
                android:textSize="11sp"
                android:typeface="monospace" />

        </LinearLayout>

        <!-- Stage 1: Detection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F0FE"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stage 1: Detection (det.onnx)"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnStage1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶ Run"
                    android:textSize="12sp"
                    android:padding="4dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvStage1Result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(not run)"
                android:textSize="11sp"
                android:typeface="monospace" />

        </LinearLayout>

        <!-- Stage 2: Post-process -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F0FE"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stage 2: Post-process (BBox)"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnStage2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶ Run"
                    android:textSize="12sp"
                    android:padding="4dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvStage2Result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(not run)"
                android:textSize="11sp"
                android:typeface="monospace" />

        </LinearLayout>

        <!-- Stage 3: Crop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF8E1"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stage 3: Crop"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnStage3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶ Run"
                    android:textSize="12sp"
                    android:padding="4dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvStage3Result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(not run)"
                android:textSize="11sp"
                android:typeface="monospace" />

        </LinearLayout>

        <!-- Stage 4: Recognition -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stage 4: Recognition (rec.onnx)"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnStage4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶ Run"
                    android:textSize="12sp"
                    android:padding="4dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvStage4Result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(not run)"
                android:textSize="11sp"
                android:typeface="monospace" />

        </LinearLayout>

        <!-- Stage 5: Full Pipeline -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FCE4EC"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stage 5: Full Pipeline (det→rec)"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnStage5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶ Run All"
                    android:textSize="12sp"
                    android:padding="4dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvStage5Result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(not run)"
                android:textSize="11sp"
                android:typeface="monospace" />

        </LinearLayout>

        <!-- In-app Log output (for CC to read via screenshot or copy) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 App Log (Logcat: -s VerificationActivity:* OnnxOcrEngine:*)"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="12dp" />

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="#1A1A1A"
            android:padding="4dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(waiting...)"
                android:textSize="10sp"
                android:typeface="monospace"
                android:textColor="#00FF00"
                android:fontFamily="monospace" />

        </ScrollView>

    </LinearLayout>

</ScrollView>
